def rotate_matrix(matrix, direction):
    if direction == 'right': 
        return [list(row) for row in zip(*matrix[::-1])]
    elif direction == 'left': 
        return [list(row) for row in zip(*matrix)][::-1]
    else:
        raise ValueError("Direction must be 'left' or 'right'")





